{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "autoPort": true,
      "cwd": "frontend"
    },
    {
      "name": "backend",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "cd backend && uv run uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000} --reload"],
      "port": 8000,
      "autoPort": true
    }
  ]
}
