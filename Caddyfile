{$DOMAIN:localhost} {
    handle /api/* {
        reverse_proxy backend:8000
    }

    handle {
        root * /srv

        # Hashed assets — cache forever (Vite adds content hashes to filenames)
        @immutable path /assets/*
        header @immutable Cache-Control "public, max-age=31536000, immutable"

        # index.html and sw.js — always revalidate with server
        @nocache path / /index.html /sw.js /registerSW.js
        header @nocache Cache-Control "no-cache, no-store, must-revalidate"

        try_files {path} /index.html
        file_server
    }
}
